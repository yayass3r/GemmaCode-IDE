# ─── GemmaCode IDE Environment Variables ───

# Database (optional - core IDE works without it)
# For local development with SQLite:
DATABASE_URL="file:./db/custom.db"
# For Vercel production with PostgreSQL (Supabase/Neon):
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# AI SDK (z-ai-web-dev-sdk handles auth automatically)
# No manual API keys needed - the SDK manages authentication

# App Settings
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# NEXT_PUBLIC_APP_URL="https://your-vercel-app.vercel.app"
