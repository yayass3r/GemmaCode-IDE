# ─── GemmaCode IDE Environment Variables ───

# Database (optional - core IDE works without it)
# For local development with SQLite:
DATABASE_URL="file:./db/custom.db"
# For Vercel production with PostgreSQL (Supabase/Neon):
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# JWT Secret (REQUIRED for production - generate a strong random key)
JWT_SECRET="change-me-to-a-strong-random-key"

# ─── AI Configuration ───
# AI Chat uses z-ai-web-dev-sdk (Cloud API) — no manual configuration needed.
# The SDK automatically connects to Z.ai Cloud API.
# Works on any hosting: Vercel, Netlify, Railway, Render, etc.

# App Settings
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# NEXT_PUBLIC_APP_URL="https://your-vercel-app.vercel.app"
