# ─── GemmaCode IDE Environment Variables ───

# Database (optional - core IDE works without it)
# For local development with SQLite:
DATABASE_URL="file:./db/custom.db"
# For Vercel production with PostgreSQL (Supabase/Neon):
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# JWT Secret (REQUIRED for production - generate a strong random key)
JWT_SECRET="change-me-to-a-strong-random-key"

# ─── AI Configuration (REQUIRED for AI Chat to work) ───
# The AI server requires authentication via X-Token header.
# Set these environment variables to enable the AI chat feature.

# ZAI_BASE_URL - AI server endpoint URL
# Default: http://172.25.136.193:8080/v1 (internal dev server)
# For production, set this to your public AI endpoint
ZAI_BASE_URL="http://172.25.136.193:8080/v1"

# ZAI_API_KEY - API key for Authorization header
ZAI_API_KEY="Z.ai"

# ZAI_TOKEN - REQUIRED: Auth token for X-Token header
# This token is required by the AI server for authentication.
# Without this, the AI chat will return a 503 error.
# Get this token from your AI service provider or platform admin.
# ZAI_TOKEN="your-ai-token-here"

# Optional: Chat and User IDs for AI session tracking
# ZAI_CHAT_ID="your-chat-id"
# ZAI_USER_ID="your-user-id"

# App Settings
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# NEXT_PUBLIC_APP_URL="https://your-vercel-app.vercel.app"
